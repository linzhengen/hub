# Patterns to ignore when building packages.
# This supports file globs, relative path matching, and negation (prefixed with !).
# For more information, see: https://helm.sh/docs/chart_template_guide/helm_ignore_file/

# Common development files
.git/
.gitignore
.gitmodules
.gitattributes
.gitkeep

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Log files
*.log
*.log.*

# Environment files
.env
.env.local
.env.*.local

# Go specific
*.test
*.out
vendor/

# Build directories
dist/
build/
bin/
out/

# Temporary files
tmp/
*.tmp

# Documentation
README.md
LICENSE
CHANGELOG.md

# Test files
*_test.go
testdata/

# Configuration files not needed in chart
.dockerignore
Dockerfile
docker-compose*.yml
Makefile
go.mod
go.sum
